# Familit – 환경변수 예시
# 실제 값은 .env 파일에만 입력하세요. .env 는 절대 커밋하지 마세요.

# ── Supabase (Lovable Cloud / 기존 Supabase 프로젝트 모두 동일)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── 앱 설정
VITE_APP_NAME=Familit

# ⚠️ 절대 프론트엔드(.env / VITE_*)에 service_role 키를 넣지 마세요.
# service_role 키는 Supabase Edge Function / 서버 전용 환경변수로만 사용합니다.
